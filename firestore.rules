// firestore.rules
// Production-ready Firestore Security Rules for UChat
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isOwnerAccount() {
      // Check Firebase Auth token email directly — no Firestore read needed, never fails
      return isAuth() && (
        request.auth.token.email == 'support.uchat@gmail.com' ||
        request.auth.token.email == 'help.uchat@outlook.com'
      );
    }

    function isAdmin() {
      return isAuth() && (
        isOwnerAccount() ||
        // Fallback: check user doc role field (admin OR owner)
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'owner'])
      );
    }

    function isNotBanned() {
      // Only do the expensive get() if the user is authenticated
      // Use a fallback of false if banned field doesn't exist (means not banned)
      return isAuth() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('banned', false) != true
      );
    }

    function isProfileComplete() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profileSetupComplete == true;
    }

    function isValidUsername(username) {
      return username.matches('^[a-z0-9_.]{3,30}$');
    }

    // ─── Users ──────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isAuth();

      // Allow user to create their own document.
      // Previously this hardcoded `role == 'user'` and `verified == false`, but
      // authService.js's ensureUserDocument() sets role:'owner'/verified:true
      // for the two designated owner emails — meaning the owner account's very
      // first Firestore doc-create was always rejected by these rules, throwing
      // an uncaught error during sign-in (manifesting as "login successful but
      // app never loads").
      allow create: if isAuth() && request.auth.uid == uid
        && (
          (request.resource.data.role == 'user' && request.resource.data.verified == false) ||
          (request.resource.data.role == 'owner' && isOwnerAccount())
        )
        && request.resource.data.banned == false;

      // Users can update their own profile but NOT sensitive fields
      allow update: if isAuth() && (
        // Own profile (limited fields)
        (request.auth.uid == uid && isNotBanned() &&
          !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'verified', 'banned', 'blacklisted', 'uid', 'email'])
        ) ||        // Admins can update most fields
        (isAdmin() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['email']))  ||
        // Any authenticated user can increment/decrement follow counts on any user
        // (triggered by follow/unfollow — the follower/following collections gate abuse)
        (isAuth() && isNotBanned() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['followersCount', 'followingCount'])) ||
        // Credits exactly +1 invite to ANOTHER user (fired when someone signs up
        // via their ?ref= link). `verified`/`verifiedViaTrial`/`verifiedTrialUntil`
        // may only change in the exact same write where inviteCount crosses the
        // 50-invite threshold, and verified can only be forced to true — never
        // false — so this can't be abused to grant arbitrary verification or to
        // unverify someone else.
        (isAuth() && isNotBanned() && request.auth.uid != uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['inviteCount', 'verified', 'verifiedViaTrial', 'verifiedTrialUntil', 'updatedAt']) &&
          request.resource.data.inviteCount == (resource.data.inviteCount == null ? 0 : resource.data.inviteCount) + 1 &&
          (
            request.resource.data.inviteCount < 50 ||
            (request.resource.data.verified == true && request.resource.data.verifiedViaTrial == true)
          )
        ) ||
        // Own system fields (posts, reels count, online status)
        (isAuth() && request.auth.uid == uid && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['postsCount', 'reelsCount', 'onlineStatus', 'lastSeen']))
      );

      allow delete: if isOwnerAccount();
    }

    // ─── Posts ──────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned() && isProfileComplete()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.authorId == request.auth.uid ||
        (isNotBanned() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likesCount', 'commentsCount', 'sharesCount', 'savedCount']))
      );
      allow delete: if isAuth() && (
        resource.data.authorId == request.auth.uid || isAdmin()
      );
    }

    // ─── Reels ──────────────────────────────────────────────────────────────

    match /reels/{reelId} {
      // Public read so shared reel links work without login
      allow read: if true;
      allow create: if isAuth() && isNotBanned() && isProfileComplete()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.authorId == request.auth.uid ||
        (isNotBanned() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likesCount', 'commentsCount', 'viewsCount', 'sharesCount', 'repostsCount']))
      );
      allow delete: if isAuth() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ─── Comments ───────────────────────────────────────────────────────────

    match /comments/{commentId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth() && resource.data.authorId == request.auth.uid;
      allow delete: if isAuth() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ─── Likes ──────────────────────────────────────────────────────────────

    match /likes/{likeId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ─── Saves (works for both posts and reels — see `type` field) ──────────

    match /saves/{saveId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ─── Reposts ──────────────────────────────────────────────────────────────

    match /reposts/{repostId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ─── Followers / Following ───────────────────────────────────────────────

    match /followers/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.followerId == request.auth.uid ||
        // Lets someone who just blocked this follower remove the stale
        // "they follow me" relationship as part of blockUser() — without
        // this, blocking only severed the blocker's own follow, not the
        // target's follow of the blocker, since deleting another user's
        // follow doc isn't normally allowed.
        (resource.data.userId == request.auth.uid &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          resource.data.followerId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('blockedUsers', []))
      );
    }

    match /following/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        // Mirrors the followers rule above — lets a blocker remove the
        // target's "following the blocker" record too.
        (resource.data.followingId == request.auth.uid &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          resource.data.userId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('blockedUsers', []))
      );
    }

    // ─── Chats ──────────────────────────────────────────────────────────────

    match /chats/{chatId} {
      allow read: if isAuth() && (
        request.auth.uid in resource.data.participants || isAdmin()
      );
      allow create: if isAuth() && isNotBanned()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() && (
        request.auth.uid in resource.data.participants || isAdmin()
      );
      allow delete: if false; // Chats cannot be deleted (only messages)
    }

    // ─── Messages ───────────────────────────────────────────────────────────

    match /messages/{messageId} {
      // Any authenticated user may read messages — chatIds are private UUIDs
      // only known to participants, so knowing the chatId = being a participant.
      // This also covers old messages that pre-date the participants[] field.
      allow read: if isAuth() && isNotBanned();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        isAdmin() ||
        // "Delete for me" (deletedFor) must be updatable by ANY participant,
        // not just the sender — otherwise only the sender could ever hide a
        // message from their own view, which is exactly backwards.
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'seenBy', 'seenAt', 'deliveredTo', 'deletedFor'])
      );
      allow delete: if false;
    }

    // ─── Notifications ───────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuth() && isNotBanned();
      allow update: if isAuth() && resource.data.recipientId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuth() && resource.data.recipientId == request.auth.uid;
    }

    // ─── Notes ───────────────────────────────────────────────────────────────

    match /notes/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid && isNotBanned();
    }

    // ─── Reports ─────────────────────────────────────────────────────────────

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.reporterUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isOwnerAccount();
    }

    // ─── Calls ───────────────────────────────────────────────────────────────

    match /calls/{callId} {
      allow read: if isAuth() && (
        resource.data.callerId == request.auth.uid ||
        resource.data.calleeId == request.auth.uid
      );
      allow create: if isAuth() && isNotBanned()
        && request.resource.data.callerId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.callerId == request.auth.uid ||
        resource.data.calleeId == request.auth.uid
      );

      // ICE candidates subcollections
      match /callerCandidates/{candId} {
        allow read, write: if isAuth();
      }
      match /calleeCandidates/{candId} {
        allow read, write: if isAuth();
      }
    }

    // ─── Reel Views ──────────────────────────────────────────────────────────

    match /reelViews/{viewId} {
      allow read: if isAuth();
      allow create, update: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ─── Guest Counter ────────────────────────────────────────────────────────
    // Stores a simple incrementing number used to generate sequential guest
    // usernames (guest0000001, guest0000002, …). Contains no sensitive data.

    match /_counters/{counterId} {
      allow read, write: if isAuth();
    }

    // ─── Usernames index ──────────────────────────────────────────────────────

    match /usernames/{username} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── Feedback / Support / Verification requests ───────────────────────────

    match /feedback/{docId} {
      allow read: if isAdmin();
      // Allow any user (including unauthenticated guests) to submit feedback
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ─── Post Views (one per user per post) ───────────────────────────────────
    match /postViews/{viewId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ─── Shares (lightweight log for 30-day analytics — not user-attributed) ──
    match /shares/{shareId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ─── Deny all else ────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
